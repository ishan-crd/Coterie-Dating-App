<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Google Sign-In needs the app's REVERSED iOS client ID registered as a URL
	  scheme. Replace YOUR_REVERSED_CLIENT_ID below with the value Google Cloud
	  Console shows for your iOS OAuth client (it looks like
	  com.googleusercontent.apps.1234567890-abcdef). This is just your client ID
	  with the two halves swapped.
	-->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Circle uses your location to set where you’re based and help you find people nearby.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.1076938664897-f9a3rgdt00clkpqmq217vg8v4hgl1fou</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
